# ─────────────────────────────────────────────────────────────────────────────
# MyTourDataViewer – Backend local development environment variables
# Copy this file to .env and adjust values, or set them in appsettings.json.
# ASP.NET Core reads these as overrides on top of appsettings.json.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database provider ────────────────────────────────────────────────────────
# "sqlite"   – local file (default)
# "postgres" – requires a running PostgreSQL instance
DbProvider=sqlite

# ── Connection strings ────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Data Source=mytourviewer.db
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=mytourviewer;Username=postgres;Password=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Key MUST be at least 32 characters.
Jwt__Key=CHANGE_ME_IN_DEVELOPMENT_32_CHARS_MIN
Jwt__Issuer=MyTourDataViewer
Jwt__Audience=MyTourDataViewerClients
Jwt__ExpiryMinutes=60

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
