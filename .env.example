# ─────────────────────────────────────────────────────────────────────────────
# MyTourDataViewer – Docker Compose environment variables
# Copy this file to .env and adjust values before running docker-compose up.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database provider ────────────────────────────────────────────────────────
# "sqlite"   – uses a local SQLite file (default, no extra service needed)
# "postgres" – uses the bundled PostgreSQL service defined in docker-compose.yml
DB_PROVIDER=sqlite

# ── SQLite connection (used when DB_PROVIDER=sqlite) ─────────────────────────
SQLITE_CONNECTION=Data Source=/data/mytourviewer.db

# ── PostgreSQL connection (used when DB_PROVIDER=postgres) ───────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mytourviewer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT settings ──────────────────────────────────────────────────────────────
# Key MUST be at least 32 characters and kept secret in production.
JWT_KEY=CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN
JWT_ISSUER=MyTourDataViewer
JWT_AUDIENCE=MyTourDataViewerClients
JWT_EXPIRY_MINUTES=60

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# ── Port mappings (host:container) ───────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=4200
POSTGRES_EXTERNAL_PORT=5432
