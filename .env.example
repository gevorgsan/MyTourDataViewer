# ─────────────────────────────────────────────────────────────────────────────
# MyTourDataViewer – Docker Compose environment variables
# Copy this file to .env and adjust values before running docker-compose up.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database provider ────────────────────────────────────────────────────────
# "sqlite"   – uses a local SQLite file (default, no extra service needed)
# "postgres" – uses the bundled PostgreSQL service defined in docker-compose.yml
DB_PROVIDER=sqlite

# ── SQLite connection (used when DB_PROVIDER=sqlite) ─────────────────────────
SQLITE_CONNECTION=Data Source=/data/mytourviewer.db

# ── PostgreSQL connection (used when DB_PROVIDER=postgres) ───────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mytourviewer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT settings ──────────────────────────────────────────────────────────────
# Key MUST be at least 32 characters and kept secret in production.
JWT_KEY=CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN
JWT_ISSUER=MyTourDataViewer
JWT_AUDIENCE=MyTourDataViewerClients
JWT_EXPIRY_MINUTES=60

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
# Container-internal port used by the CMD in the backend Dockerfile.
# Set to 5000 here so local Docker Compose keeps the existing port mapping.
# On Render, PORT is injected automatically; the Dockerfile fallback is 8080.
PORT=5000

# ── Port mappings (host:container) ───────────────────────────────────────────
BACKEND_PORT=5000
POSTGRES_EXTERNAL_PORT=5432

# ── CORS (backend) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For Render:   CORS_ORIGINS=https://my-frontend.onrender.com
# For Fly.io:   CORS_ORIGINS=https://mytour-frontend.fly.dev
CORS_ORIGINS=http://localhost:4200

# ── Frontend API base URL ─────────────────────────────────────────────────────
# Backend origin used by the React app to make API calls.
# Set to the backend service URL without a trailing slash.
# For local dev:  VITE_API_BASE_URL=http://localhost:5263
# For Render:     VITE_API_BASE_URL is set via fromService in render.yaml and
#                 embedded into the JS bundle at build time by Vite.
VITE_API_BASE_URL=http://localhost:5263
